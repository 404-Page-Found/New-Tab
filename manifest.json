{
  "manifest_version": 3,
  "name": "New Tab",
  "version": "0.3.9",
  "description": "A beautiful new tab page with clock, search, apps, and todo list",
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "chrome_url_overrides": {
    "newtab": "New-Tab.html"
  },
  "permissions": [
    "storage"
  ],
  "action": {
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png"
    }
  }
}
